# Twilio Configuration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Neon/PostgreSQL Configuration
# Example: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# API Keys
GROQ_API_KEY=
FISH_AUDIO_API_KEY=
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=
DEEPGRAM_API_KEY=
SARVAM_API_KEY=
CAL_API_KEY=

# Authentication
JWT_SECRET_KEY=

# Runtime Toggles
USE_CLOUD_STT=true
STT_PROVIDER=groq
USE_CLOUD_TTS=false
USE_CLOUD_LLM=true

# LLM Configuration
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3:8b
GROQ_MODEL=llama-3.3-70b-versatile
REASONING_MODEL=qwen/qwen3-32b

# Landing Page Agent Configuration
LANDING_PAGE_AGENT_ID=

# Backend Configuration
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Voice Gateway Configuration
VOICE_GATEWAY_PORT=8001
VOICE_GATEWAY_HOST=0.0.0.0
VOICE_GATEWAY_URL=
VOICE_GATEWAY_WS_URL=

# Ngrok Configuration
NGROK_AUTH_TOKEN=

# Model Settings
WHISPER_MODEL=base
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
FISH_VOICE_ID=af

# Environment
ENVIRONMENT=development
