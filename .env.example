# Core services
DATABASE_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
GROQ_API_KEY=
SARVAM_API_KEY=
CAL_API_KEY=

# Auth and admin
JWT_SECRET_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Runtime toggles
STT_PROVIDER=groq
USE_CLOUD_STT=true
USE_CLOUD_LLM=true

# LLM
GROQ_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3:8b

# URLs and ports
VOICE_GATEWAY_URL=
VOICE_GATEWAY_WS_URL=
VOICE_GATEWAY_HOST=0.0.0.0
VOICE_GATEWAY_PORT=8001
BACKEND_URL=http://backend:8000

# Optional tuning
LANDING_PAGE_AGENT_ID=
CORS_ORIGINS=
REDIS_URL=redis://localhost:6379
DB_POOL_SIZE=10
WOW_USER_ID=

# Tunnel (docker-compose uses this exact name)
NGROK_AUTHTOKEN=
